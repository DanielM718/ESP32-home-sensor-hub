          },
          "query": "aggregateMean = from(bucket: \"environment\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"air_quality_15m\")\n  |> filter(fn: (r) => r._field == \"co2_mean\" or r._field == \"pm25_mean\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({r with _field: if r._field == \"co2_mean\" then \"CO2 15m mean\" else \"PM2.5 15m mean\"}))\n\naggregateMax = from(bucket: \"environment\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"air_quality_15m\")\n  |> filter(fn: (r) => r._field == \"co2_max\" or r._field == \"pm25_max\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> map(fn: (r) => ({r with _field: if r._field == \"co2_max\" then \"CO2 15m maximum\" else \"PM2.5 15m maximum\"}))\n\nlive = from(bucket: \"environment_live\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"air_quality_reading\")\n  |> filter(fn: (r) => r._field == \"co2\" or r._field == \"pm25\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({r with _field: r._field + \" live\"}))\n\nunion(tables: [aggregateMean, aggregateMax, live])",
          "refId": "A"
        }
      ],
