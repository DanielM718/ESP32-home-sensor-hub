# Copy values from this file into server/backend/.env on the Raspberry Pi.
# Do not commit real secrets.

# Deployment
APP_ENV=production
TZ=America/New_York
PI_HOSTNAME=sensor-pi
SERVICE_USER=home-sensor
PROJECT_ROOT=/opt/home-sensor/server

# Flask dashboard
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
GUNICORN_WORKERS=2
LOG_LEVEL=INFO
NODE_STALE_AFTER_SECONDS=1800

# MQTT broker
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_KEEPALIVE_SECONDS=60
MQTT_CLIENT_ID=home-sensor-bridge
MQTT_QOS=1
MQTT_MAX_PAYLOAD_BYTES=4096
MQTT_GATEWAY_USERNAME=home_sensor_gateway
MQTT_GATEWAY_PASSWORD=change-this-gateway-mqtt-password
MQTT_USERNAME=home_sensor_bridge
MQTT_PASSWORD=change-this-mqtt-password
MQTT_SENSOR_TOPIC=home/sensors/+
MQTT_AIR_TOPIC=home/air/+

# InfluxDB OSS v2
INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_ORG=home
INFLUXDB_BUCKET=environment
INFLUXDB_RETENTION=0
INFLUXDB_TOKEN=change-this-influxdb-write-token
INFLUXDB_WRITE_TOKEN=change-this-influxdb-write-token
INFLUXDB_READ_TOKEN=change-this-influxdb-read-token
# Used only while running scripts/setup_influxdb.sh on the Pi.
# Prefer entering these interactively or exporting them in the shell.
INFLUXDB_ADMIN_USERNAME=admin
INFLUXDB_ADMIN_PASSWORD=
INFLUXDB_ADMIN_TOKEN=

# Grafana
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

# Tailscale setup-only values.
# Do not keep TAILSCALE_AUTHKEY in server/backend/.env after setup.
TAILSCALE_HOSTNAME=sensor-pi
TAILSCALE_AUTHKEY=
TAILSCALE_ADVERTISE_TAGS=tag:home-sensor
TAILSCALE_ENABLE_SSH=0

# Optional future notification integrations
NTFY_TOPIC=
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
