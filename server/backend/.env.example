# Copy this file to server/backend/.env on the Raspberry Pi.
# Restrict permissions on the real file to the service user.

APP_ENV=production
TZ=America/New_York
PROJECT_ROOT=/opt/home-sensor/server
LOG_LEVEL=INFO

FLASK_HOST=0.0.0.0
FLASK_PORT=8080
GUNICORN_WORKERS=2
NODE_STALE_AFTER_SECONDS=1800
SEN66_EXPECTED_PUBLISH_SECONDS=5
SEN66_STALE_AFTER_SECONDS=20
SEN66_24H_MINIMUM_COVERAGE_PERCENT=75
SEN66_RECOVERY_LOOKBACK_MINUTES=30

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_KEEPALIVE_SECONDS=60
MQTT_CLIENT_ID=home-sensor-bridge
MQTT_QOS=1
MQTT_MAX_PAYLOAD_BYTES=4096
MQTT_USERNAME=home_sensor_bridge
MQTT_PASSWORD=change-this-mqtt-password
MQTT_SENSOR_TOPIC=home/sensors/+
MQTT_AIR_TOPIC=home/air/+

INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_ORG=home
INFLUXDB_BUCKET=environment
INFLUXDB_LIVE_BUCKET=environment_live
INFLUXDB_LIVE_RETENTION=72h
INFLUXDB_TOKEN=change-this-influxdb-write-token
INFLUXDB_WRITE_TOKEN=change-this-influxdb-write-token
INFLUXDB_READ_TOKEN=change-this-influxdb-read-token

GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
