# Copy to /opt/home-assistant/.env and set mode 0600.
# Use the dedicated Mosquitto account created by server/scripts/create_mqtt_users.sh.
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=home_assistant
MQTT_PASSWORD=change_me
MQTT_QOS=1

# SHT41 nodes currently publish every 15 minutes. A 30-minute default tolerates
# one missed packet. Tune only after observing the live publishing interval.
SENSOR_STALE_AFTER_SECONDS=1800
DISCOVERY_PREFIX=homeassistant
LOG_LEVEL=INFO
